DATABASE_URL=ws://localhost:8001
DATABASE_NS=pavilion
DATABASE_DB=pavilion
DATABASE_USER=root
DATABASE_PASS=root
JWT_SECRET=change-me-in-production
RUSTFS_ENDPOINT=http://localhost:9002
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_BUCKET=pavilion
QDRANT_ENDPOINT=http://localhost:6336
HOST=0.0.0.0
PORT=3000
BASE_URL=http://localhost:3000
PRETTY_LOGS=true
RUST_LOG=pavilion=debug,tower_http=debug

# Payments (leave empty to disable — self-hosted instances can run without Stripe)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
FACILITATION_FEE_PCT=5.0

# Metadata enrichment (TMDB handles both TMDB and IMDB lookups — get a free key at themoviedb.org)
TMDB_API_KEY=
